meta {
  name: Get Auth Token
  type: http
  seq: 1
}

post {
  url: https://{{APIM_ENV}}.api.service.nhs.uk/oauth2/token
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  grant_type: client_credentials
  client_assertion_type: urn:ietf:params:oauth:client-assertion-type:jwt-bearer
}

script:pre-request {
